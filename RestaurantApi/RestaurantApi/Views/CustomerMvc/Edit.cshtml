@model RestaurantApi.Models.Customer

<style>
    body {
        margin: 0;
        background: linear-gradient(135deg, #1e1e2f, #2a2a40);
        font-family: Inter;
    }

    .overlay {
        position: fixed;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.6);
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .modal {
        background: #2f2f45;
        padding: 25px;
        border-radius: 15px;
        width: 350px;
        color: white;
    }

    input {
        width: 100%;
        padding: 10px;
        margin-top: 10px;
        border-radius: 8px;
        border: none;
    }

    button {
        margin-top: 15px;
        padding: 10px;
        border-radius: 10px;
        border: none;
        background: #6c5ce7;
        color: white;
        cursor: pointer;
    }
</style>

<div class="overlay">
    <div class="modal">

        <h3>Edit Customer</h3>

        <form asp-action="Edit" asp-controller="CustomerMvc" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="CustomerId" />

            <input type="hidden" asp-for="CustomerId" />

            <input asp-for="Name" placeholder="Name" />
            <input asp-for="Phone" placeholder="Phone" />
            <input asp-for="Email" placeholder="Email" />

            <button type="submit">Save</button>

            <button type="button"
                    onclick="location.href='/CustomerMvc'">
                Cancel
            </button>

        </form>

    </div>
</div>